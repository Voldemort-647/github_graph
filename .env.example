# ─────────────────────────────────────────────
#  GitHub Graph Explorer — Environment Variables
# ─────────────────────────────────────────────

# GitHub Personal Access Token (optional but strongly recommended)
# Authenticated requests get 5000 req/hr vs 60 req/hr unauthenticated
# Create one at: https://github.com/settings/tokens
# Required scopes: (none) — public data only needs no scopes
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Neo4j AuraDB Free connection details
# Get these from: https://console.neo4j.io  → Create Free Instance
# Copy the connection URI and credentials from the downloaded .env file
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-auradb-password

# Seed users to import on first run (comma-separated GitHub logins)
SEED_USERS=torvalds,gaearon,tj

# How many pages of followers/following to fetch (default: 1, max: 10)
# Each page = 30 users. Keep low to avoid hitting rate limits.
MAX_PAGES=2

# Max repos per user to process (default: 20)
MAX_REPOS_PER_USER=20

# Max contributors per repo to process (default: 10)
MAX_CONTRIBUTORS_PER_REPO=10
